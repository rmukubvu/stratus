{
 "Resources": {
  "InlineFunctionRole": {
   "Type": "AWS::IAM::Role",
   "Properties": {
    "AssumeRolePolicyDocument": {
     "Version": "2012-10-17",
     "Statement": [
      {
       "Effect": "Allow",
       "Principal": {
        "Service": "lambda.amazonaws.com"
       },
       "Action": "sts:AssumeRole"
      }
     ]
    },
    "Policies": [
     {
      "PolicyDocument": {
       "Version": "2012-10-17",
       "Statement": [
        {
         "Effect": "Allow",
         "Action": [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
         ],
         "Resource": "*"
        }
       ]
      },
      "PolicyName": "inline-logs"
     }
    ],
    "RoleName": "stratus-inline-httpapi-role"
   },
   "Metadata": {
    "aws:cdk:path": "StratusInlineHttpApi/InlineFunctionRole"
   }
  },
  "InlineFunction": {
   "Type": "AWS::Lambda::Function",
   "Properties": {
    "Code": {
     "ZipFile": "def main(event, context):\n    return {\n        'statusCode': 200,\n        'headers': {'content-type': 'application/json'},\n        'body': '{\"ok\": true, \"source\": \"cdk\"}'\n    }"
    },
    "FunctionName": "stratus-inline-httpapi",
    "Handler": "index.main",
    "Role": {
     "Fn::GetAtt": [
      "InlineFunctionRole",
      "Arn"
     ]
    },
    "Runtime": "python3.11",
    "Timeout": 10
   },
   "Metadata": {
    "aws:cdk:path": "StratusInlineHttpApi/InlineFunction"
   }
  },
  "HttpApi": {
   "Type": "AWS::ApiGatewayV2::Api",
   "Properties": {
    "Name": "stratus-inline-httpapi",
    "ProtocolType": "HTTP"
   },
   "Metadata": {
    "aws:cdk:path": "StratusInlineHttpApi/HttpApi"
   }
  },
  "LambdaIntegration": {
   "Type": "AWS::ApiGatewayV2::Integration",
   "Properties": {
    "ApiId": {
     "Ref": "HttpApi"
    },
    "IntegrationType": "AWS_PROXY",
    "IntegrationUri": {
     "Fn::GetAtt": [
      "InlineFunction",
      "Arn"
     ]
    },
    "PayloadFormatVersion": "2.0"
   },
   "Metadata": {
    "aws:cdk:path": "StratusInlineHttpApi/LambdaIntegration"
   }
  },
  "HelloRoute": {
   "Type": "AWS::ApiGatewayV2::Route",
   "Properties": {
    "ApiId": {
     "Ref": "HttpApi"
    },
    "RouteKey": "GET /hello",
    "Target": {
     "Fn::Join": [
      "",
      [
       "integrations/",
       {
        "Ref": "LambdaIntegration"
       }
      ]
     ]
    }
   },
   "Metadata": {
    "aws:cdk:path": "StratusInlineHttpApi/HelloRoute"
   }
  },
  "DefaultStage": {
   "Type": "AWS::ApiGatewayV2::Stage",
   "Properties": {
    "ApiId": {
     "Ref": "HttpApi"
    },
    "AutoDeploy": true,
    "StageName": "$default"
   },
   "Metadata": {
    "aws:cdk:path": "StratusInlineHttpApi/DefaultStage"
   }
  },
  "InvokePermission": {
   "Type": "AWS::Lambda::Permission",
   "Properties": {
    "Action": "lambda:InvokeFunction",
    "FunctionName": {
     "Ref": "InlineFunction"
    },
    "Principal": "apigateway.amazonaws.com"
   },
   "Metadata": {
    "aws:cdk:path": "StratusInlineHttpApi/InvokePermission"
   }
  },
  "CDKMetadata": {
   "Type": "AWS::CDK::Metadata",
   "Properties": {
    "Analytics": "v2:deflate64:H4sIAAAAAAAA/zWLwQqCQBBAv8X7OtlS0DWEoFOhHxCjrjLqzoo7q4Tsv4dFp/cO72nQpwtkCa4+rZshHamCrRSsB4Wrf22EFvKWCzcaNaKtGoQtb/kWuBZyrPKWn2a25D05jgon6lDMiu9Ff8PrRHtzZzHdjP+lcEHMLqVgZ2Lc9RFkChIVu8ZA7w+LPsMRsqT3ROkcWMgaKH78APm+f3q2AAAA"
   },
   "Metadata": {
    "aws:cdk:path": "StratusInlineHttpApi/CDKMetadata/Default"
   }
  }
 },
 "Outputs": {
  "ApiEndpoint": {
   "Value": {
    "Fn::GetAtt": [
     "HttpApi",
     "ApiEndpoint"
    ]
   }
  }
 }
}